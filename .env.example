# PostgreSQL connection
POSTGRES_USER=sreality
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sreality
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full async DSN — used by SQLAlchemy and Alembic
DATABASE_URL=postgresql+asyncpg://sreality:changeme@localhost:5432/sreality

# Sync DSN — used by Alembic's env.py for migrations (asyncpg doesn't support synchronous alembic)
DATABASE_URL_SYNC=postgresql+psycopg2://sreality:changeme@localhost:5432/sreality

# Scraper behaviour
SCRAPE_DELAY_SECONDS=2
SCRAPE_MAX_RETRIES=3
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; sreality-scraper/1.0)

# Scheduler
SCRAPE_CRON=0 6 * * *

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json          # "json" for production, "pretty" for development

# Failure alerts (leave ALERT_EMAIL blank to disable)
ALERT_EMAIL=
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=scraper@localhost
